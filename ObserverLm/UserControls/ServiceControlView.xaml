<UserControl x:Class="ObserverLm.ServiceControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ObserverLm"
             Height="Auto" Width="Auto">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:ServiceStatusToColorConverter x:Key="StatusToColorConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Управление службами" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Services}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Индикатор состояния -->
                            <Ellipse Width="12" Height="12" 
                                     Fill="{Binding Status, Converter={StaticResource StatusToColorConverter}}" 
                                     Margin="0,0,5,0" VerticalAlignment="Center"/>

                            <!-- Информация о службе -->
                            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="5,0">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Status}"/>
                            </StackPanel>

                            <!-- Кнопки управления и индикатор занятости -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Content="Запустить" 
                                        Command="{Binding DataContext.StartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}" 
                                        IsEnabled="{Binding CanStart}" 
                                        Margin="2" Padding="5,2"/>
                                <Button Content="Остановить" 
                                        Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}" 
                                        IsEnabled="{Binding CanStop}" 
                                        Margin="2" Padding="5,2"/>
                                <ProgressBar IsIndeterminate="True" 
                                             Width="30" Height="10" 
                                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                                             Margin="2"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Кнопка обновления статусов -->
        <Button Grid.Row="2" Content="Обновить" Command="{Binding RefreshCommand}" 
                Margin="0,10,0,0" HorizontalAlignment="Right" Padding="10,5"/>
    </Grid>
</UserControl>
