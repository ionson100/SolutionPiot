<UserControl x:Class="ObserverLm.UserControls.CurlControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ObserverLm.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="FullCopyTextBoxStyle" TargetType="TextBox">
            <!-- Отступ справа, чтобы текст не заходил под иконку -->
            <Setter Property="Padding" Value="5,5,28,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <!-- Основная рамка текстового поля -->
                            <Border x:Name="border" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            Background="{TemplateBinding Background}" 
                            SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false"/>
                            </Border>

                            <!-- Кнопка копирования -->
                            <Button 
                               x:Name="ButtonCopy"
                               Click="CopyButton_Click" 
                               ToolTip="Копировать содержимое"
                               HorizontalAlignment="Right" 
                               VerticalAlignment="Top"
                               Margin="0,4,6,0"
                               Width="25" Height="25"
                               Content="📋"
                               FontSize="12">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Foreground" Value="Gray"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <!-- Убираем стандартный системный шаблон кнопки -->
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>

                                        <Style.Triggers>
                                            <!-- Наведение: синий цвет и легкий фон -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#007ACC"/>
                                                <Setter Property="Background" Value="#15000000"/>
                                            </Trigger>
                                            <!-- Клик: темно-синий и эффект нажатия -->
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Foreground" Value="#005A9E"/>
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBox Grid.Row="0" 
                 Style="{StaticResource FullCopyTextBoxStyle}" 
                 x:Name="OutputTextBoxR"
                
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontSize="20"
                 FontWeight="Bold"
                 FontFamily="Consolas, Courier New, monospace"
                 ToolTip="CURL запрос"/>

    </Grid>
</UserControl>
