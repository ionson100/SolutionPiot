<UserControl x:Class="ObserverLm.UserControls.LogsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <!-- Определяем три строки: верхняя, разделитель, нижняя -->
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TopRow" Height="*" />
            <!-- Занимает 50% (динамически) -->
            <RowDefinition Height="Auto" />
            <!-- Высота под размер разделителя -->
            <RowDefinition Height="*" />
            <!-- Занимает оставшиеся 50% -->
        </Grid.RowDefinitions>

        <!-- Верхнее текстовое поле -->
        <ListBox Grid.Row="0" 
                 SelectionMode="Extended"
                 Name="LogMonitor1"
                 FontFamily="Consolas"
                 FontSize="12"
                 Background="Black" 
                 Foreground="LightGray"
                 BorderThickness="0">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Копировать" Click="CopyMenuItem_Click" />
                </ContextMenu>
            </ListBox.ContextMenu>

        </ListBox>

        <!-- Горизонтальный разделитель (GridSplitter) -->
        <GridSplitter Grid.Row="1" 
                      Height="4" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Center" 
                      Background="#EEE" 
                      ShowsPreview="True" />

        <!-- Нижнее текстовое поле -->
        <ListBox Grid.Row="2" 
                 SelectionMode="Extended"
                 Name="LogMonitor2"
                 FontFamily="Consolas"
                 FontSize="12"
                 Background="Black" 
                 Foreground="LightGray"
                 BorderThickness="0">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Копировать" Click="CopyMenuItem_Click" />
                </ContextMenu>
            </ListBox.ContextMenu>

        </ListBox>
    </Grid>
</UserControl>

