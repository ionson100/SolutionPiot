<UserControl x:Class="ObserverLm.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ObserverLm"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="60"/>
          
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Параметр 1 -->
        <Label Content="URL:"  FontWeight="Bold" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox Name="TxtUrl"  Style="{StaticResource EditOrder}" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="5"/>

        <!-- Параметр 2 -->
        <Label Content="BASIC:" FontWeight="Bold" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox Name="TxtBasic" Style="{StaticResource EditOrder}" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="5"/>

        <!-- Параметр 3 -->
        <Label Content="TOKEN:" FontWeight="Bold" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox Name="TxtToken" Style="{StaticResource EditOrder}" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="5"/>

        <Label Content="TAIL:" FontWeight="Bold" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox Name="TxtTail" Style="{StaticResource EditOrder}"
                 PreviewTextInput="NumberValidationTextBox" 
                 DataObject.Pasting="TextBox_Pasting"
                 Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="5"/>

        <!-- Параметр 4 (с кнопкой выбора папки) -->
        <Label Content="FOLDER LOG:" FontWeight="Bold" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox Name="TxtFolderPath" Style="{StaticResource EditOrder}" Grid.Row="4" Grid.Column="1" Margin="5"/>
        <Button Content=". . ." Grid.Row="4" Grid.Column="2" Width="100" Margin="5" Click="BtnBrowse_Click"/>
        <Button Content="Сохранить" Grid.Row="5" Grid.Column="1" Style="{StaticResource ButtonHeadPaneStyle}"  Height="50" 
                HorizontalAlignment="Right" Width="150" Margin="5" Click="ButtonBase_OnClick"/>


    </Grid>
</UserControl>
